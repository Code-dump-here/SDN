<!DOCTYPE html>
<html>
<head>
  <title>New Question</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar', { currentPage: 'questions' }) %>
  <div class="container mt-5">
    <h2 class="mb-4">Create New Question</h2>
    <div class="card p-4">
      <form action="<%= typeof quizId !== 'undefined' ? ('/quizzes/' + quizId + '/question') : '/questions' %>" method="POST">
        <div class="mb-3">
          <label for="text" class="form-label">Question Text</label>
          <textarea class="form-control" id="text" name="text" rows="3" required></textarea>
        </div>
        <div class="mb-3">
          <label for="options" class="form-label">Options (comma separated)</label>
          <input type="text" class="form-control" id="options" name="options" placeholder="e.g. Paris, London, Berlin, Madrid" required>
        </div>
        <div class="mb-3">
          <label for="correctAnswerIndex" class="form-label">Correct Answer Index</label>
          <input type="number" class="form-control" id="correctAnswerIndex" name="correctAnswerIndex" min="0" placeholder="e.g. 0 for first option" required>
        </div>
        <button type="submit" class="btn btn-primary">Create</button>
        <a href="<%= typeof quizId !== 'undefined' ? ('/quizzes/' + quizId) : '/questions' %>" class="btn btn-secondary ms-2">Cancel</a>
      </form>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
