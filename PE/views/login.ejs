<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Login</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/>
</head>
<body class="d-flex align-items-center vh-100 bg-light">

  <div class="card mx-auto shadow-sm" style="max-width: 400px; width: 100%;">
    <div class="card-header text-center fw-bold fs-5">
      Apartment Manager Login
    </div>
    <div class="card-body">
      <% if (error && error.length) { %>
        <div class="alert alert-danger"><%= error[0] %></div>
      <% } %>
      <form method="POST" action="/auth/signin">
        <div class="mb-3">
          <label for="un" class="form-label">Username</label>
          <input type="text" name="un" id="un" class="form-control" required autofocus/>
        </div>
        <div class="mb-3">
          <label for="pw" class="form-label">Password</label>
          <input type="password" name="pw" id="pw" class="form-control" required/>
        </div>
        <div class="d-grid">
          <button type="submit" class="btn btn-primary">Sign In</button>
        </div>
      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
