<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Residents</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/>
</head>
<body class="bg-light">

<!-- Navbar -->
<nav class="navbar navbar-dark bg-dark px-4">
  <span class="navbar-brand fw-bold">Apartment Manager</span>
  <a href="/auth/logout" class="btn btn-outline-light btn-sm">Logout</a>
</nav>

<div class="container py-4">

  <!-- Flash messages -->
  <% if (error && error.length) { %>
    <div class="alert alert-danger"><%= error[0] %></div>
  <% } %>
  <% if (success && success.length) { %>
    <div class="alert alert-success"><%= success[0] %></div>
  <% } %>

  <!-- Header + Add button -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Residents (<%= residents.length %>)</h4>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">+ Add Resident</button>
  </div>

  <!-- Card grid -->
  <div class="row row-cols-1 row-cols-md-3 g-3">
    <% residents.forEach(function(r) { %>
    <div class="col">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title"><%= r.residentName %></h5>
          <p class="card-text text-muted small"><%= r.residentDescription %></p>
          <p class="mb-1"><span class="badge bg-primary">Floor <%= r.floor %></span></p>
          <p class="mb-1 small">Age: <strong><%= new Date().getFullYear() - r.yOB %></strong></p>
          <p class="mb-1">
            <% if (r.isOwned) { %>
              <span class="badge bg-success">Owner</span>
            <% } else { %>
              <span class="badge bg-secondary">Tenant</span>
            <% } %>
          </p>
          <p class="mb-2 small">Apartment: <strong><%= r.apartment ? r.apartment.apartmentName : 'N/A' %></strong></p>
        </div>
        <div class="card-footer d-flex gap-2">
          <button class="btn btn-outline-primary btn-sm"
            onclick='openEditModal(<%- JSON.stringify(r) %>)'>Edit</button>
          <form method="POST" action="/view/residents/<%= r._id %>?_method=DELETE"
            onsubmit="return confirm('Delete this resident?')">
            <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
          </form>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Resident</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/view/residents">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Resident Name</label>
            <input type="text" name="residentName" class="form-control" required/>
          </div>
          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="residentDescription" class="form-control" rows="2" required></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label">Floor (1–40)</label>
            <input type="number" name="floor" class="form-control" min="1" max="40" required/>
          </div>
          <div class="mb-3">
            <label class="form-label">Age (1–95)</label>
            <input type="number" name="age" class="form-control" min="1" max="95" required/>
          </div>
          <div class="mb-3">
            <label class="form-label">Apartment</label>
            <select name="apartment" class="form-select" required>
              <option value="">Select apartment</option>
              <% apartments.forEach(function(a) { %>
                <option value="<%= a._id %>"><%= a.apartmentName %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" name="isOwned" id="addIsOwned"/>
            <label class="form-check-label" for="addIsOwned">Owner</label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Add</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Edit Resident</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" id="editForm">
        <input type="hidden" name="_method" value="PUT"/>
        <input type="hidden" id="editId"/>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Resident Name</label>
            <input type="text" name="residentName" id="editResidentName" class="form-control" required/>
          </div>
          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="residentDescription" id="editResidentDescription" class="form-control" rows="2" required></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label">Floor (1–40)</label>
            <input type="number" name="floor" id="editFloor" class="form-control" min="1" max="40" required/>
          </div>
          <div class="mb-3">
            <label class="form-label">Age (1–95)</label>
            <input type="number" name="age" id="editAge" class="form-control" min="1" max="95" required/>
          </div>
          <div class="mb-3">
            <label class="form-label">Apartment</label>
            <select name="apartment" id="editApartment" class="form-select" required>
              <option value="">Select apartment</option>
              <% apartments.forEach(function(a) { %>
                <option value="<%= a._id %>"><%= a.apartmentName %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" name="isOwned" id="editIsOwned"/>
            <label class="form-check-label" for="editIsOwned">Owner</label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
const currentYear = new Date().getFullYear();
function openEditModal(r) {
  document.getElementById('editResidentName').value = r.residentName;
  document.getElementById('editResidentDescription').value = r.residentDescription;
  document.getElementById('editFloor').value = r.floor;
  document.getElementById('editAge').value = currentYear - r.yOB;
  document.getElementById('editIsOwned').checked = r.isOwned;
  document.getElementById('editApartment').value = r.apartment._id;
  document.getElementById('editForm').action = '/view/residents/' + r._id;
  new bootstrap.Modal(document.getElementById('editModal')).show();
}
</script>
</body>
</html>
