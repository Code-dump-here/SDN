<!DOCTYPE html>
<html>
<head>
  <title>Question Detail</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar', { currentPage: 'questions' }) %>
  <div class="container mt-5">
    <div class="card p-4">
      <h4 class="mb-3"><%= question.text %></h4>
      <div class="mb-3">
        <strong>Options:</strong>
        <span>
          <%= question.options.map((opt, i) => opt + (i === question.correctAnswerIndex ? ' (Correct)' : '')).join(', ') %>
        </span>
      </div>
      <div class="d-flex">
        <a href="/questions/<%= question._id %>/edit" class="btn btn-warning me-2">Edit Question</a>
        <a href="/questions" class="btn btn-secondary">Back to Questions</a>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
