

<head>
  <title>Question Detail</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container mt-5">
    <div class="card p-4">
      <span class="fs-4 fw-bold mb-3"><%= question.text %></span>
      <div class="mb-3"><strong>Answer:</strong> <%= question.answer %></div>
      <a href="/questions/<%= question._id %>/edit" class="btn btn-warning me-2">Edit Question</a>
      <a href="/questions" class="btn btn-secondary">Back to Questions</a>
    </div>
  </div>
</body>

