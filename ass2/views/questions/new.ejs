

<head>
  <title>New Question</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container mt-5">
    <div class="card p-4">
      <form action="/questions" method="POST">
        <div class="mb-3">
          <label for="text" class="form-label">Question Text</label>
          <input type="text" class="form-control" id="text" name="text" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Options</label>
          <div id="options-container">
            <div class="input-group mb-1 option-row">
              <div class="input-group-text">
                <input type="radio" name="correctAnswerIndex" value="0" required>
              </div>
              <input type="text" class="form-control" name="options[]" placeholder="Option" required>
              <button type="button" class="btn btn-danger remove-option">Remove</button>
            </div>
            <div class="input-group mb-1 option-row">
              <div class="input-group-text">
                <input type="radio" name="correctAnswerIndex" value="1" required>
              </div>
              <input type="text" class="form-control" name="options[]" placeholder="Option" required>
              <button type="button" class="btn btn-danger remove-option">Remove</button>
            </div>
          </div>
          <button type="button" class="btn btn-secondary mt-1" id="add-option">Add Option</button>
        </div>
        <button type="submit" class="btn btn-primary">Create</button>
        <a href="/questions" class="btn btn-secondary ms-2">Cancel</a>
      </form>
    </div>
  </div>
</body>
    </div>
    <div class="mb-3">
      <label class="form-label">Keywords</label>
      <div id="keywords-container">
        <div class="input-group mb-1">
          <input type="text" class="form-control" name="keywords[]" placeholder="Keyword">
          <button type="button" class="btn btn-danger remove-keyword">Remove</button>
        </div>
      </div>
      <button type="button" class="btn btn-secondary mt-1" id="add-keyword">Add Keyword</button>
    </div>

    <button type="button" class="btn btn-success" id="confirm-create">Create Question</button>
    <div class="container mt-4">
      <h2 class="mb-4">Create New Question</h2>
      <form action="<%= typeof quizId !== 'undefined' ? ('/quizzes/' + quizId + '/question') : '/questions' %>" method="POST">
        <div class="mb-3">
          <label for="text" class="form-label">Question Text</label>
          <input type="text" class="form-control" id="text" name="text" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Options</label>
          <div id="options-container">
            <div class="input-group mb-1 option-row">
              <div class="input-group-text">
                <input type="radio" name="correctAnswerIndex" value="0" required>
              </div>
              <input type="text" class="form-control" name="options[]" placeholder="Option" required>
              <button type="button" class="btn btn-danger remove-option">Remove</button>
            </div>
            <div class="input-group mb-1 option-row">
              <div class="input-group-text">
                <input type="radio" name="correctAnswerIndex" value="1" required>
              </div>
              <input type="text" class="form-control" name="options[]" placeholder="Option" required>
              <button type="button" class="btn btn-danger remove-option">Remove</button>
            </div>
          </div>
          <button type="button" class="btn btn-secondary mt-1" id="add-option">Add Option</button>
        </div>
        <div class="mb-3">
          <label class="form-label">Keywords</label>
          <div id="keywords-container">
            <div class="input-group mb-1">
              <input type="text" class="form-control" name="keywords[]" placeholder="Keyword">
              <button type="button" class="btn btn-danger remove-keyword">Remove</button>
            </div>
          </div>
          <button type="button" class="btn btn-secondary mt-1" id="add-keyword">Add Keyword</button>
        </div>
        <button type="button" class="btn btn-primary" id="confirm-create">Create</button>
        <a href="/questions" class="btn btn-secondary ms-2">Cancel</a>
      </form>
      <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
      <script>
        document.addEventListener('DOMContentLoaded', function() {
          document.getElementById('confirm-create').onclick = async function(e) {
            const form = e.target.form;
            const text = form.text.value;
            const options = Array.from(form.querySelectorAll('input[name="options[]"]')).map(i => i.value).filter(v => v.trim() !== '');
            const keywords = Array.from(form.querySelectorAll('input[name="keywords[]"]')).map(i => i.value).filter(v => v.trim() !== '');
            const correctRadio = form.querySelector('input[name="correctAnswerIndex"]:checked');
            const correctAnswerIndex = correctRadio ? parseInt(correctRadio.value) : null;
            const body = {
              text,
              options,
              keywords,
              correctAnswerIndex
            };
            if (!text || options.length < 2 || correctAnswerIndex === null) {
              alert('Please fill out all required fields and select the correct answer.');
              return;
            }
            if (!options[correctAnswerIndex]) {
              alert('Selected correct answer index does not match any option.');
              return;
            }
            if (!confirm('Submit this question?\n' + JSON.stringify(body, null, 2))) {
              return;
            }
            try {
              const response = await axios.post('/api/questions', body);
              if (response.data.success) {
                alert('Question created successfully!');
                window.location.href = '/questions';
              } else {
                alert('Error: ' + response.data.error);
              }
            } catch (err) {
              alert('Request failed: ' + (err.response?.data?.error || err.message));
            }
          };
        });
      </script>
      <script>
        document.addEventListener('DOMContentLoaded', function() {
          // Options
          const optionsContainer = document.getElementById('options-container');
          document.getElementById('add-option').onclick = function() {
            const optionCount = optionsContainer.querySelectorAll('.option-row').length;
            const div = document.createElement('div');
            div.className = 'input-group mb-1 option-row';
            div.innerHTML = `<div class=\"input-group-text\"><input type=\"radio\" name=\"correctAnswerIndex\" value=\"${optionCount}\" required></div><input type=\"text\" class=\"form-control\" name=\"options[]\" placeholder=\"Option\" required><button type=\"button\" class=\"btn btn-danger remove-option\">Remove</button>`;
            optionsContainer.appendChild(div);
            updateRadioValues();
          };
          optionsContainer.addEventListener('click', function(e) {
            if (e.target.classList.contains('remove-option')) {
              if (optionsContainer.querySelectorAll('.option-row').length > 2) {
                e.target.parentElement.remove();
                updateRadioValues();
              }
            }
          });
          function updateRadioValues() {
            const rows = optionsContainer.querySelectorAll('.option-row');
            rows.forEach((row, idx) => {
              const radio = row.querySelector('input[type="radio"]');
              radio.value = idx;
            });
          }
          const keywordsContainer = document.getElementById('keywords-container');
          document.getElementById('add-keyword').onclick = function() {
            const div = document.createElement('div');
            div.className = 'input-group mb-1';
            div.innerHTML = `<input type="text" class="form-control" name="keywords[]" placeholder="Keyword"><button type="button" class="btn btn-danger remove-keyword">Remove</button>`;
            keywordsContainer.appendChild(div);
          };
          keywordsContainer.addEventListener('click', function(e) {
            if (e.target.classList.contains('remove-keyword')) {
              e.target.parentElement.remove();
            }
          });
        });
      </script>
    </div>

