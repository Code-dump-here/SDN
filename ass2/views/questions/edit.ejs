<!DOCTYPE html>
<html>
<head>
  <title>Edit Question</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Question Bank</a>
      <div class="navbar-nav">
        <a class="nav-link" href="/quizzes">Quizzes</a>
        <a class="nav-link" href="/questions">Questions</a>
      </div>
    </div>
  </nav>
  <div class="container mt-5">
    <h2 class="mb-4">Edit Question</h2>
    <div class="card p-4">
      <form action="/questions/<%= question._id %>?_method=PUT" method="POST">
        <div class="mb-3">
          <label for="text" class="form-label">Question Text</label>
          <textarea class="form-control" id="text" name="text" rows="3" required><%= question.text %></textarea>
        </div>
        <div class="mb-3">
          <label for="options" class="form-label">Options (comma separated)</label>
          <input type="text" class="form-control" id="options" name="options" value="<%= question.options.join(', ') %>" required>
        </div>
        <div class="mb-3">
          <label for="correctAnswerIndex" class="form-label">Correct Answer Index</label>
          <input type="number" class="form-control" id="correctAnswerIndex" name="correctAnswerIndex" min="0" value="<%= question.correctAnswerIndex %>" required>
        </div>
        <button type="submit" class="btn btn-primary">Update</button>
        <a href="/questions/<%= question._id %>" class="btn btn-secondary ms-2">Cancel</a>
      </form>
    </div>
  </div>
</body>
</html>
