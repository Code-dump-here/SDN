<!DOCTYPE html>
<html>
<head>
  <title>Questions List</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Question Bank</a>
      <div class="navbar-nav">
        <a class="nav-link" href="/quizzes">Quizzes</a>
        <a class="nav-link active" href="/questions">Questions</a>
      </div>
    </div>
  </nav>
  <div class="container mt-5">
    <div class="card p-4">
      <span class="fs-4 fw-bold mb-3">List of Questions</span>
      <a href="/questions/new" class="btn btn-primary mb-3">Create New Question</a>
      <ul class="list-group">
        <% questions.forEach(function(question) { %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <a href="/questions/<%= question._id %>" class="text-decoration-none"><%= question.text %></a>
            <form action="/questions/<%= question._id %>?_method=DELETE" method="POST" class="d-inline">
              <button type="submit" class="btn btn-danger btn-sm">Delete</button>
            </form>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>
</body>
</html>
