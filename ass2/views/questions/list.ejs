<!DOCTYPE html>
<html>
<head>
  <title>Questions List</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar', { currentPage: 'questions' }) %>
  <div class="container mt-5">
    <span class="fs-4 fw-bold mb-4">List of Questions</span>
    <a href="/questions/new" class="btn btn-primary mb-4 ms-3">Create New Question</a>
    <ul class="list-group list-group-open">
      <% questions.forEach(function(question) { %>
        <li class="list-group-item d-flex justify-content-between align-items-center list-group-item-open">
          <div>
            <a href="/questions/<%= question._id %>" class="fw-bold text-decoration-none"><%= question.text %></a>
          </div>
          <form action="/questions/<%= question._id %>?_method=DELETE" method="POST" class="d-inline">
            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
          </form>
        </li>
      <% }) %>
    </ul>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
