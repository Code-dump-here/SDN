<!DOCTYPE html>
<html>
<head>
  <title>Quiz Detail</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Question Bank</a>
      <div class="navbar-nav">
        <a class="nav-link active" href="/quizzes">Quizzes</a>
        <a class="nav-link" href="/questions">Questions</a>
      </div>
    </div>
  </nav>
  <div class="container mt-5">
    <div class="card p-4">
      <span class="fs-4 fw-bold mb-3"><%= quiz.title %></span>
      <div class="mb-3"><strong>Description:</strong> <%= quiz.description %></div>
      <h4 class="mt-4">Questions</h4>
      <ul class="list-group mb-3">
        <% questions.forEach(function(question) { %>
          <li class="list-group-item"><%= question.text %></li>
        <% }) %>
      </ul>
      <div class="d-flex">
        <a href="/quizzes/<%= quiz._id %>/question" class="btn btn-success me-2">Add Question</a>
        <a href="/quizzes/<%= quiz._id %>/edit" class="btn btn-warning me-2">Edit Quiz</a>
        <a href="/quizzes" class="btn btn-secondary">Back to Quizzes</a>
      </div>
    </div>
  </div>
</body>
</html>
