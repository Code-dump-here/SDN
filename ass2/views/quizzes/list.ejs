<!DOCTYPE html>
<html>
<head>
  <title>Quizzes List</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Question Bank</a>
      <div class="navbar-nav">
        <a class="nav-link active" href="/quizzes">Quizzes</a>
        <a class="nav-link" href="/questions">Questions</a>
      </div>
    </div>
  </nav>
  <div class="container mt-5">
    <span class="fs-4 fw-bold mb-4">List of Quizzes</span>
    <a href="/quizzes/new" class="btn btn-primary mb-4 ms-3">Create New Quiz</a>
    <ul class="list-group list-group-open">
      <% quizzes.forEach(function(quiz) { %>
        <li class="list-group-item d-flex justify-content-between align-items-center list-group-item-open">
          <div>
            <a href="/quizzes/<%= quiz._id %>" class="fw-bold text-decoration-none"><%= quiz.title %></a><br>
            <small class="text-muted"><%= quiz.description %></small>
          </div>
          <form action="/quizzes/<%= quiz._id %>?_method=DELETE" method="POST" class="d-inline">
            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
          </form>
        </li>
      <% }) %>
    </ul>
  </div>
</body>
</html>
